{
  "name": "xiaoyu-toolbox",
  "private": true,
  "version": "2.2.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "preview": "vite preview",
    "worker:dev": "wrangler dev",
    "build": "run-s lint commitlog type-check build-only",
    "debug:ls": "echo '--- Checking dist directory structure ---' && ls -laR dist || echo 'dist directory not found'",
    "build-only": "vite-ssg build || (npm run debug:ls && exit 1)",
    "lint": "run-s lint:oxlint lint:eslint",
    "lint-check": "run-s lint:*-check",
    "lint-full": "run-s lint type-check format",
    "lint:oxlint": "oxlint . --fix",
    "lint:eslint": "eslint . --cache --fix",
    "lint:oxlint-check": "oxlint .",
    "lint:eslint-check": "eslint . --cache",
    "type-check": "golar --build",
    "format": "prettier --write --experimental-cli src/",
    "readme": "tsx scripts/readme.ts",
    "commitlog": "tsx scripts/commitLog.ts",
    "prepare": "husky"
  },
